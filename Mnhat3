local function CreateToggle(txt, parent, y, callback)
    local f = Instance.new("Frame", parent)
    f.Size = UDim2.new(1,-20,0,52)
    f.Position = UDim2.new(0,10,0,y)
    f.BackgroundTransparency = 1

    local l = Instance.new("TextLabel", f)
    l.Size = UDim2.new(0.65,0,1,0)
    l.BackgroundTransparency = 1
    l.Text = txt
    l.TextColor3 = Color3.new(1,1,1)
    l.Font = Enum.Font.Gotham
    l.TextSize = 15
    l.TextXAlignment = Enum.TextXAlignment.Left

    local t = Instance.new("TextButton", f)
    t.Size = UDim2.new(0,68,0,32)
    t.Position = UDim2.new(1,-80,0.5,-16)
    t.BackgroundColor3 = Color3.fromRGB(60,60,65)
    t.Text = "OFF"
    Instance.new("UICorner", t).CornerRadius = UDim.new(0,16)

    local s = false
    t.MouseButton1Click:Connect(function()
        s = not s
        t.Text = s and "ON" or "OFF"
        t.BackgroundColor3 = s and Color3.fromRGB(0,255,160) or Color3.fromRGB(60,60,65)
        callback(s)
    end)
end

local function CreateSlider(txt, parent, y, minv, maxv, def, callback)
    local f = Instance.new("Frame", parent)
    f.Size = UDim2.new(1,-20,0,65)
    f.Position = UDim2.new(0,10,0,y)
    f.BackgroundTransparency = 1

    local l = Instance.new("TextLabel", f)
    l.Size = UDim2.new(1,0,0,22)
    l.BackgroundTransparency = 1
    l.Text = txt .. ": " .. def
    l.TextColor3 = Color3.new(1,1,1)
    l.Font = Enum.Font.Gotham

    local bar = Instance.new("Frame", f)
    bar.Size = UDim2.new(1,0,0,9)
    bar.Position = UDim2.new(0,0,0,38)
    bar.BackgroundColor3 = Color3.fromRGB(45,45,50)
    Instance.new("UICorner", bar)

    local fill = Instance.new("Frame", bar)
    fill.Size = UDim2.new((def-minv)/(maxv-minv),0,1,0)
    fill.BackgroundColor3 = Color3.fromRGB(0,255,180)
    Instance.new("UICorner", fill)

    local dragging = false
    bar.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

    RunService.RenderStepped:Connect(function()
        if dragging then
            local x = UserInputService:GetMouseLocation().X
            local r = math.clamp((x - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
            local val = math.floor(minv + (maxv - minv) * r)
            fill.Size = UDim2.new(r,0,1,0)
            l.Text = txt .. ": " .. val
            callback(val)
        end
    end)
end

