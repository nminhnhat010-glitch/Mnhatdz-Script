-- ESP
local function NewESP(plr)
    if plr == LP then return end
    local box = Drawing.new("Square")
    box.Thickness = 2
    box.Filled = false
    local name = Drawing.new("Text")
    name.Size = 14
    name.Center = true
    name.Outline = true
    ESP[plr] = {box=box, name=name}
end

for _,p in ipairs(Players:GetPlayers()) do NewESP(p) end
Players.PlayerAdded:Connect(NewESP)

-- Main Loop
RunService.Heartbeat:Connect(function()
    if not LP.Character or not LP.Character:FindFirstChild("HumanoidRootPart") then return end
    local myHRP = LP.Character.HumanoidRootPart

    -- Kill Aura
    if KillAura then
        for _,plr in ipairs(Players:GetPlayers()) do
            if plr \~= LP and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local tHRP = plr.Character.HumanoidRootPart
                if (tHRP.Position - myHRP.Position).Magnitude <= KillAuraRange then
                    local dir = (tHRP.Position - myHRP.Position).Unit
                    pcall(function()
                        RS.Events.GameRemoteFunction:InvokeServer("AttemptWeaponHit", {
                            hitboxOffset = Vector3.new(0,0,-2),
                            knockback = 70,
                            shouldLock = true,
                            shouldSlow = true,
                            attackCooldown = 0,
                            hitboxSize = Vector3.new(HitboxSize*1.3, HitboxSize*1.6, HitboxSize*1.3),
                            damage = 9999,
                            tool = LP.Character:FindFirstChildOfClass("Tool"),
                            shouldLunge = true
                        }, {{
                            knockback = 70,
                            isClosestEnemy = true,
                            origin = myHRP.Position,
                            enemyModel = plr.Character,
                            distance = (tHRP.Position - myHRP.Position).Magnitude,
                            direction = dir
                        }})
                    end)
                    task.wait(HitDelay)
                end
            end
        end
    end

    -- Hitbox Expander
    if HitboxExpander then
        local tool = LP.Character:FindFirstChildOfClass("Tool")
        if tool then
            for _,part in pairs(tool:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.Size = Vector3.new(HitboxSize, HitboxSize, HitboxSize)
                    part.Transparency = 0.6
                    part.Color = Color3.fromRGB(255,50,150)
                    part.Material = Enum.Material.Neon
                end
            end
        end
    end

    -- Auto Chests
    if AutoBasic then pcall(function() RS.Events.GameRemoteFunction:InvokeServer("AttemptRollGachaChest","Basic") end) end
    if AutoDivine then pcall(function() RS.Events.GameRemoteFunction:InvokeServer("AttemptRollGachaChest","Divine") end) end

    -- ESP
    for plr,data in pairs(ESP) do
        local char = plr.Character
        if PlayerESP and char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local head = char:FindFirstChild("Head")
            local hum = char:FindFirstChild("Humanoid")
            if hrp and head and hum then
                local top = Camera:WorldToViewportPoint(head.Position + Vector3.new(0,0.8,0))
                local bot = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0,3,0))
                if top.Z > 0 and bot.Z > 0 then
                    local h = math.abs(top.Y - bot.Y)
                    local w = h / 2.1
                    data.box.Size = Vector2.new(w, h)
                    data.box.Position = Vector2.new(top.X - w/2, top.Y)
                    data.box.Color = Color3.fromRGB(0,255,180)
                    data.box.Visible = true
                    data.name.Text = plr.Name .. " ["..math.floor(hum.Health).."]"
                    data.name.Position = Vector2.new(top.X, top.Y-18)
                    data.name.Visible = true
                else
                    data.box.Visible = false
                    data.name.Visible = false
                end
            end
        else
            if data.box then data.box.Visible = false end
            if data.name then data.name.Visible = false end
        end
    end
end)

-- Fly + Other
RunService.RenderStepped:Connect(function()
    if AutoFly and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = LP.Character.HumanoidRootPart
        local cam = workspace.CurrentCamera
        local dir = Vector3.new()
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + cam.CFrame.RightVector end
        if dir.Magnitude > 0 then
            hrp.Velocity = dir.Unit * 120
        end
    end
end)

UserInputService.JumpRequest:Connect(function()
    if InfJump and LP.Character and LP.Character:FindFirstChild("Humanoid") then
        LP.Character.Humanoid:ChangeState("Jumping")
    end
end)

RunService.Stepped:Connect(function()
    if NoClip and LP.Character then
        for _,v in pairs(LP.Character:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end
end)

